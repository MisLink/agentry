{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true
  },
  "include": ["pi-package/**/*.ts"],
  "exclude": ["node_modules"]
}
